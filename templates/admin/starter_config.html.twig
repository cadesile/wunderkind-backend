{% extends '@EasyAdmin/layout.html.twig' %}

{% block content %}
<div class="row g-4 mt-1">

    <div class="col-12">
        <h5 class="fw-semibold mb-0">Starter Config</h5>
        <p class="text-muted small mb-0">These values define the starting conditions for every new academy. Changes take effect on the next new registration.</p>
    </div>

    <div class="col-12">
    <form method="POST" action="{{ path('admin_starter_config_save') }}">
        <input type="hidden" name="_token" value="{{ csrf_token('save_starter_config') }}">

        <div class="card">
            <div class="card-header py-2 d-flex align-items-center gap-2">
                <i class="fa fa-flag text-muted"></i>
                <span class="fw-semibold small">New Academy Defaults</span>
            </div>
            <div class="card-body">
                <div class="row g-3">

                    <div class="col-md-6">
                        <label for="startingBalance" class="form-label fw-semibold small">Starting Balance (pence)</label>
                        <input type="number" id="startingBalance" name="startingBalance"
                               value="{{ config.startingBalance }}"
                               min="0" class="form-control">
                        <div class="form-text">Stored in pence — £50,000 = 5,000,000. Default: 5,000,000</div>
                    </div>

                    <div class="col-md-6">
                        <label for="starterSponsorTier" class="form-label fw-semibold small">Starter Sponsor Tier</label>
                        <select id="starterSponsorTier" name="starterSponsorTier" class="form-select">
                            <option value="SMALL"  {% if config.starterSponsorTier == 'SMALL'  %}selected{% endif %}>SMALL</option>
                            <option value="MEDIUM" {% if config.starterSponsorTier == 'MEDIUM' %}selected{% endif %}>MEDIUM</option>
                            <option value="LARGE"  {% if config.starterSponsorTier == 'LARGE'  %}selected{% endif %}>LARGE</option>
                        </select>
                        <div class="form-text">Sponsor company-size tier assigned at academy creation. Default: SMALL</div>
                    </div>

                    <div class="col-md-4">
                        <label for="starterPlayerCount" class="form-label fw-semibold small">Players</label>
                        <input type="number" id="starterPlayerCount" name="starterPlayerCount"
                               value="{{ config.starterPlayerCount }}"
                               min="0" class="form-control">
                        <div class="form-text">Players assigned at academy creation. Default: 5</div>
                    </div>

                    <div class="col-md-4">
                        <label for="starterCoachCount" class="form-label fw-semibold small">Coaches</label>
                        <input type="number" id="starterCoachCount" name="starterCoachCount"
                               value="{{ config.starterCoachCount }}"
                               min="0" class="form-control">
                        <div class="form-text">Coaches assigned at academy creation. Default: 1</div>
                    </div>

                    <div class="col-md-4">
                        <label for="starterScoutCount" class="form-label fw-semibold small">Scouts</label>
                        <input type="number" id="starterScoutCount" name="starterScoutCount"
                               value="{{ config.starterScoutCount }}"
                               min="0" class="form-control">
                        <div class="form-text">Scouts assigned at academy creation. Default: 1</div>
                    </div>

                </div>
            </div>
        </div>

        <div class="mt-4">
            <button type="submit" class="btn btn-primary btn-sm">Save Starter Config</button>
        </div>
    </form>
    </div>

</div>
{% endblock %}
