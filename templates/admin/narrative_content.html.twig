{% extends '@EasyAdmin/layout.html.twig' %}

{% block content %}
<div class="row g-4 mt-1">

    <div class="col-12">
        <h5 class="fw-semibold mb-0">Narrative Content — Import / Export</h5>
        <p class="text-muted small mb-0">
            Export all narrative content (event templates, facility templates, player archetypes) to a single JSON file.
            Import a file to upsert content by slug or name — existing records are updated, new ones are created.
            Use this to develop and test locally, then import to the external API.
        </p>
    </div>

    {# ── Export ──────────────────────────────────────────────────────────── #}
    <div class="col-12 col-lg-6">
        <div class="card h-100">
            <div class="card-header py-2 d-flex align-items-center gap-2">
                <i class="fa fa-file-arrow-down text-primary"></i>
                <span class="fw-semibold small">Export</span>
            </div>
            <div class="card-body d-flex flex-column gap-3">
                <p class="text-muted small mb-0">
                    Downloads a <code>.json</code> snapshot of all narrative content in this environment.
                    The file is safe to commit to version control for local development workflows.
                </p>
                <ul class="small text-muted mb-0 ps-3">
                    <li>Event templates (all categories)</li>
                    <li>Facility templates (active and inactive)</li>
                    <li>Player archetypes</li>
                </ul>
                <div class="mt-auto">
                    <a href="{{ path('admin_narrative_export') }}" class="btn btn-primary btn-sm">
                        <i class="fa fa-download me-1"></i> Download JSON
                    </a>
                </div>
            </div>
        </div>
    </div>

    {# ── Import ──────────────────────────────────────────────────────────── #}
    <div class="col-12 col-lg-6">
        <div class="card h-100 border-warning">
            <div class="card-header py-2 d-flex align-items-center gap-2 bg-warning-subtle">
                <i class="fa fa-file-arrow-up text-warning"></i>
                <span class="fw-semibold small">Import</span>
            </div>
            <div class="card-body d-flex flex-column gap-3">
                <p class="text-muted small mb-0">
                    Upload a previously exported <code>.json</code> file. Each record is matched by
                    <strong>slug</strong> (templates) or <strong>name</strong> (archetypes) and upserted —
                    existing records are updated in-place, new records are created.
                </p>
                <div class="alert alert-warning py-2 small mb-0">
                    <i class="fa fa-triangle-exclamation me-1"></i>
                    <strong>This does not delete existing records.</strong>
                    Records absent from the import file are left untouched.
                </div>
                <form method="POST" action="{{ path('admin_narrative_import') }}" enctype="multipart/form-data" class="mt-auto">
                    <input type="hidden" name="_token" value="{{ csrf_token('narrative_import') }}">
                    <div class="mb-3">
                        <label for="narrative_file" class="form-label small fw-semibold">JSON file</label>
                        <input class="form-control form-control-sm" type="file" id="narrative_file"
                               name="narrative_file" accept=".json,application/json" required>
                    </div>
                    <div class="mb-3 p-2 border border-danger rounded">
                        <div class="form-check form-switch mb-0">
                            <input class="form-check-input" type="checkbox" role="switch"
                                   id="clear_before_import" name="clear_before_import">
                            <label class="form-check-label small fw-semibold text-danger" for="clear_before_import">
                                Clear existing data before importing
                            </label>
                        </div>
                        <p class="text-muted small mb-0 mt-1">
                            Deletes all event templates, facility templates, and player archetypes before applying the import file. Cannot be undone.
                        </p>
                    </div>
                    <button type="submit" class="btn btn-warning btn-sm">
                        <i class="fa fa-upload me-1"></i> Import
                    </button>
                </form>
            </div>
        </div>
    </div>

</div>
{% endblock %}
