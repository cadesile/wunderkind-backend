<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Settings & Developer Tools — Wunderkind Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet">
    <style>
        body { background: #f8f9fa; }
        .page-header { background: #fff; border-bottom: 1px solid #dee2e6; padding: 1rem 1.5rem; margin-bottom: 2rem; }
        .page-header a { color: #6c757d; text-decoration: none; font-size: .875rem; }
        .page-header a:hover { color: #0d6efd; }
        .card { border: 1px solid #dee2e6; box-shadow: 0 1px 3px rgba(0,0,0,.06); }
        .card-title { font-size: 1rem; font-weight: 600; }
    </style>
</head>
<body>

<div class="page-header d-flex align-items-center gap-3">
    <a href="{{ path('admin') }}"><i class="fa fa-arrow-left me-1"></i> Back to Dashboard</a>
    <span class="text-muted">|</span>
    <span class="fw-semibold"><i class="fa fa-cogs me-1"></i> Settings &amp; Developer Tools</span>
</div>

<div class="container-fluid px-4">

    {% for type, messages in app.flashes %}
        {% for message in messages %}
            <div class="alert alert-{{ type == 'error' or type == 'danger' ? 'danger' : (type == 'warning' ? 'warning' : (type == 'success' ? 'success' : 'info')) }} alert-dismissible fade show" role="alert">
                {{ message|raw }}
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        {% endfor %}
    {% endfor %}

    <h5 class="mb-1">Developer Tools</h5>
    <p class="text-muted small mb-4">These operations affect live data. Use with caution in production.</p>

    <div class="row g-3">

        <div class="col-md-4">
            <div class="card h-100">
                <div class="card-body">
                    <h6 class="card-title text-warning"><i class="fa fa-user-clock me-1"></i> Age-21 Deletion</h6>
                    <p class="card-text text-muted small">
                        Runs the age-out check across every academy. Players who have turned 21 are permanently deleted (with Guardian and Transfer cascade).
                    </p>
                </div>
                <div class="card-footer bg-transparent">
                    <a href="{{ path('admin_trigger_age21') }}"
                       class="btn btn-warning btn-sm"
                       data-confirm="Permanently delete all players aged 21+ from every academy?">
                        Run Age-21 Check
                    </a>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card h-100">
                <div class="card-body">
                    <h6 class="card-title text-info"><i class="fa fa-broom me-1"></i> Cleanup Old Assigned Entities</h6>
                    <p class="card-text text-muted small">
                        Permanently deletes players, staff, sponsors, and investors that were assigned to academies more than 52 weeks ago.
                    </p>
                </div>
                <div class="card-footer bg-transparent">
                    <a href="{{ path('admin_cleanup_entities') }}"
                       class="btn btn-info btn-sm text-white"
                       data-confirm="Delete all assigned entities older than 52 weeks?">
                        Run Cleanup
                    </a>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card h-100">
                <div class="card-body">
                    <h6 class="card-title text-danger"><i class="fa fa-database me-1"></i> Reset &amp; Seed Database</h6>
                    <p class="card-text text-muted small">
                        Wipes all academy and game data, preserves admin users, and re-seeds the market pool. Must be run from the CLI — cannot be executed from the browser.
                    </p>
                    <code class="d-block mt-2 p-2 bg-light rounded small">bash scripts/reset_and_seed.sh</code>
                </div>
                <div class="card-footer bg-transparent">
                    <a href="{{ path('admin_reset_database') }}" class="btn btn-outline-secondary btn-sm">
                        Show Instructions
                    </a>
                </div>
            </div>
        </div>

    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
document.querySelectorAll('[data-confirm]').forEach(el => {
    el.addEventListener('click', e => {
        if (!confirm(el.dataset.confirm)) e.preventDefault();
    });
});
</script>
</body>
</html>
