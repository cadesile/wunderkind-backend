{% extends '@EasyAdmin/layout.html.twig' %}

{% block content %}
<div class="row g-4 mt-1">

    {# ── Game Configuration ───────────────────────────────────────────── #}
    <div class="col-12">
        <h6 class="text-muted text-uppercase fw-semibold mb-1" style="letter-spacing:.08em;font-size:.75rem;border-left:3px solid var(--bs-primary, #0d6efd);padding-left:.5rem;">Game Configuration</h6>
        <p class="text-muted small mb-0 ps-2">Global tuning values synced to mobile clients on an hourly basis.</p>
    </div>

    <div class="col-12">
        <form method="POST" action="{{ path('admin_settings_save_config') }}">
            <input type="hidden" name="_token" value="{{ csrf_token('save_config') }}">
            <div class="card">
                <div class="card-header py-2 d-flex align-items-center gap-2">
                    <i class="fa fa-people-group text-muted"></i>
                    <span class="fw-semibold small">Clique System</span>
                </div>
                <div class="card-body">
                    <p class="text-muted small mb-3">
                        A clique forms when 3+ players all have pairwise relationship values above the threshold.
                        Total cliqued players across all cliques cannot exceed the squad cap %.
                        Example: squad of 10, cap 30% → max 3 cliqued players → one clique of 3 maximum.
                        Squad drops to 9 → cap becomes 2 → clique disbands automatically.
                    </p>
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label for="cliqueRelationshipThreshold" class="form-label fw-semibold small">Relationship Threshold</label>
                            <input type="number" id="cliqueRelationshipThreshold" name="cliqueRelationshipThreshold"
                                   value="{{ config.cliqueRelationshipThreshold }}"
                                   min="-100" max="100" class="form-control">
                            <div class="form-text">Min pairwise value for clique eligibility. Default: 20</div>
                        </div>
                        <div class="col-md-4">
                            <label for="cliqueSquadCapPercent" class="form-label fw-semibold small">Squad Cap %</label>
                            <input type="number" id="cliqueSquadCapPercent" name="cliqueSquadCapPercent"
                                   value="{{ config.cliqueSquadCapPercent }}"
                                   min="0" max="100" class="form-control">
                            <div class="form-text">Max % of squad in cliques combined. Default: 30</div>
                        </div>
                        <div class="col-md-4">
                            <label for="cliqueMinTenureWeeks" class="form-label fw-semibold small">Min Tenure (weeks)</label>
                            <input type="number" id="cliqueMinTenureWeeks" name="cliqueMinTenureWeeks"
                                   value="{{ config.cliqueMinTenureWeeks }}"
                                   min="1" max="52" class="form-control">
                            <div class="form-text">Academy tenure required before clique eligibility. Default: 3</div>
                        </div>
                    </div>
                    <div class="mt-3">
                        <button type="submit" class="btn btn-primary btn-sm">Save Configuration</button>
                    </div>
                </div>
            </div>
        </form>
    </div>

    {# ── Developer Tools ───────────────────────────────────────────────── #}
    <div class="col-12 mt-2">
        <h6 class="text-muted text-uppercase fw-semibold mb-1" style="letter-spacing:.08em;font-size:.75rem;border-left:3px solid var(--bs-warning,#ffc107);padding-left:.5rem;">Developer Tools</h6>
        <p class="text-muted small mb-0 ps-2">These operations affect live data. Use with caution in production.</p>
    </div>

    {# Age-21 Deletion #}
    <div class="col-md-4">
        <div class="card h-100 border-warning">
            <div class="card-body">
                <h6 class="card-title fw-semibold small">
                    <i class="fa fa-user-clock text-warning me-1"></i> Age-21 Deletion
                </h6>
                <p class="card-text text-muted small">
                    Runs the age-out check across every academy. Players who have turned 21 are permanently deleted (with Guardian and Transfer cascade).
                </p>
            </div>
            <div class="card-footer bg-transparent">
                <form method="POST" action="{{ path('admin_trigger_age21') }}" class="d-inline" onsubmit="return confirmAction(this, 'Permanently delete all players aged 21+ from every academy?')">
                    <input type="hidden" name="_csrf_token" value="{{ csrf_token('trigger_age21') }}">
                    <button type="submit" class="btn btn-warning btn-sm">
                        <i class="fa fa-play me-1"></i> Run Age-21 Check
                    </button>
                </form>
            </div>
        </div>
    </div>

    {# Cleanup Old Assigned Entities #}
    <div class="col-md-4">
        <div class="card h-100">
            <div class="card-body">
                <h6 class="card-title fw-semibold small">
                    <i class="fa fa-broom text-secondary me-1"></i> Cleanup Old Assigned Entities
                </h6>
                <p class="card-text text-muted small">
                    Permanently deletes players, staff, sponsors, and investors that were assigned to academies more than 52 weeks ago.
                </p>
            </div>
            <div class="card-footer bg-transparent">
                <form method="POST" action="{{ path('admin_cleanup_entities') }}" class="d-inline" onsubmit="return confirmAction(this, 'Delete all assigned entities older than 52 weeks?')">
                    <input type="hidden" name="_csrf_token" value="{{ csrf_token('cleanup_entities') }}">
                    <button type="submit" class="btn btn-secondary btn-sm">
                        <i class="fa fa-play me-1"></i> Run Cleanup
                    </button>
                </form>
            </div>
        </div>
    </div>

    {# Reset & Seed — CLI only, visually de-emphasised #}
    <div class="col-md-4">
        <div class="card h-100" style="opacity:.65;">
            <div class="card-body">
                <h6 class="card-title fw-semibold small text-secondary">
                    <i class="fa fa-database me-1"></i> Reset &amp; Seed Database
                </h6>
                <p class="card-text text-muted small">
                    Wipes all academy and game data, preserves admin users, and re-seeds the market pool.
                    <strong>CLI only</strong> — cannot be executed from the browser.
                </p>
                <code class="d-block mt-2 p-2 rounded small" style="background:var(--bs-tertiary-bg,#f1f3f5);">bash scripts/reset_and_seed.sh</code>
            </div>
            <div class="card-footer bg-transparent">
                <button class="btn btn-outline-secondary btn-sm" disabled title="Run this command from the CLI">
                    <i class="fa fa-terminal me-1"></i> CLI Only
                </button>
            </div>
        </div>
    </div>

</div>

<script>
function confirmAction(form, message) {
    if (!confirm(message)) return false;
    const btn = form.querySelector('button[type="submit"]');
    if (btn) { btn.disabled = true; btn.innerHTML = '<i class="fa fa-spinner fa-spin me-1"></i> Running…'; }
    return true;
}
</script>
{% endblock %}
